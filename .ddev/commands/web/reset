#!/bin/bash

## Description: Reset the app to a fresh install state (wipes all data, triggers setup wizard)
## Usage: reset
## Example: ddev reset

echo "This will wipe ALL data including user accounts and return to the setup wizard."
echo ""
read -p "Are you sure? (y/N) " -n 1 -r
echo ""

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

php artisan app:reset --force

echo ""
echo "Visit the site to run the setup wizard."
